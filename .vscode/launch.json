    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "lumos",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "lumos (chrome :3000)",
            "request": "launch",
            "type": "dart",
            "deviceId": "chrome",
            "toolArgs": [
                "--web-hostname",
                "localhost",
                "--web-port",
                "3000"
            ]
        },
        {
            "name": "lumos (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "lumos (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}
